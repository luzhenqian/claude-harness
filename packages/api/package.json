{
  "name": "@claude-harness/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "pnpm typeorm migration:generate -d src/config/database.config.ts",
    "migration:run": "pnpm typeorm migration:run -d src/config/database.config.ts",
    "index:all": "ts-node -r tsconfig-paths/register src/index/cli/index.command.ts all",
    "index:code": "ts-node -r tsconfig-paths/register src/index/cli/index.command.ts code",
    "index:articles": "ts-node -r tsconfig-paths/register src/index/cli/index.command.ts articles"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.50",
    "@anthropic-ai/sdk": "^0.82.0",
    "@google/generative-ai": "^0.24.1",
    "@mastra/core": "^1.21.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "openai": "^6.33.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.0",
    "pgvector": "^0.2.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "ts-morph": "^27.0.2",
    "typeorm": "^0.3.20",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc/core": "^1.15.21",
    "@types/express": "^5.0.6",
    "@types/glob": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.0.0"
  }
}
